APP_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes
APP_EMAIL_DEBUG_FALLBACK=true
APP_SWAGGER_ENABLED=true
APP_MOCK_DATA_ENABLED=true
APP_AUTH_REFRESH_TOKEN_SECURE=false

MYSQL_DATABASE=mentorlink
MYSQL_ROOT_PASSWORD=replace-with-root-password
MYSQL_APP_USERNAME=mentorlink_app
MYSQL_APP_PASSWORD=replace-with-app-user-password

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true
MAIL_SMTP_SSL_TRUST=smtp.gmail.com
MAIL_SMTP_SSL_PROTOCOLS=TLSv1.2
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=5000
MAIL_SMTP_WRITE_TIMEOUT=5000
MAIL_DEBUG=false
MAIL_LOG_LEVEL=INFO
